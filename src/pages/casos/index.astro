---
import Page from '../../layouts/Page.astro';
import '../../styles/global.css';

const industries = ["Todos", "Gastronomia", "Tecnologia", "Salud", "Retail", "Educacion", "Fitness"];

const cases = [
  {
    client: "Restaurante Mar Azul",
    industry: "Gastronomia",
    service: "Social Media",
    challenge: "Baja presencia digital y poco engagement.",
    result: "+300% engagement",
    metrics: { engagement: "+300%", seguidores: "+15K", reservas: "+180%" },
    image: "https://images.unsplash.com/photo-1552566626-52f8b828add9?w=600&h=350&fit=crop"
  },
  {
    client: "TechStore Peru",
    industry: "Tecnologia",
    service: "E-commerce",
    challenge: "Lanzamiento de tienda online sin traccion.",
    result: "S/ 500K ventas mes 1",
    metrics: { ventas: "S/ 500K", roas: "5.2x", trafico: "+400%" },
    image: "https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=600&h=350&fit=crop",
    slug: "techstore-peru"
  },
  {
    client: "Clinica Salud+",
    industry: "Salud",
    service: "Google Ads",
    challenge: "Dependencia de referidos, baja visibilidad online.",
    result: "+150% citas agendadas",
    metrics: { citas: "+150%", costo: "-60%", conversion: "12.5%" },
    image: "https://images.unsplash.com/photo-1519494026892-80bbd2d6fd0d?w=600&h=350&fit=crop"
  },
  {
    client: "FreshMarket",
    industry: "Retail",
    service: "Meta Ads",
    challenge: "Expandir alcance de delivery en Lima.",
    result: "4.2x ROAS",
    metrics: { roas: "4.2x", pedidos: "+250%", cpa: "-45%" },
    image: "https://images.unsplash.com/photo-1542838132-92c53300491e?w=600&h=350&fit=crop"
  },
  {
    client: "EduPro",
    industry: "Educacion",
    service: "Desarrollo Web + Ads",
    challenge: "Plataforma de cursos sin usuarios.",
    result: "+10K descargas mes 1",
    metrics: { descargas: "+10K", registros: "+8K", retencion: "72%" },
    image: "https://images.unsplash.com/photo-1501504905252-473c47e087f8?w=600&h=350&fit=crop"
  },
  {
    client: "LimaFit",
    industry: "Fitness",
    service: "Branding + Social",
    challenge: "Cadena de gimnasios con marca desactualizada.",
    result: "+200% membresias",
    metrics: { membresias: "+200%", engagement: "+350%", alcance: "+500%" },
    image: "https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=600&h=350&fit=crop"
  }
];

const summaryMetrics = [
  { value: "+200", label: "Proyectos completados" },
  { value: "3.8x", label: "ROAS promedio" },
  { value: "+S/ 10M", label: "Generados en ventas" },
  { value: "95%", label: "Clientes satisfechos" }
];
---

<Page title="Casos de Exito | Pixel Studio">
  <section class="page-hero">
    <div class="container">
      <span class="label">Casos de Exito</span>
      <h1>Resultados que <span class="gradient-text">transforman negocios</span></h1>
      <p>Cada proyecto es una historia de crecimiento. Conoce como hemos ayudado a empresas peruanas a alcanzar sus objetivos.</p>
    </div>
  </section>

  <section class="metrics-bar">
    <div class="container">
      <div class="metrics-grid">
        {summaryMetrics.map((m) => (
          <div class="metric-item">
            <span class="metric-val">{m.value}</span>
            <span class="metric-lbl">{m.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="filters">
        {industries.map((f, i) => (
          <button class:list={["filter-btn", { active: i === 0 }]}>{f}</button>
        ))}
      </div>

      <div class="cases-grid">
        {cases.map((c) => (
          <div class="case-card" data-industry={c.industry}>
            <div class="case-img">
              <img src={c.image} alt={c.client} loading="lazy" />
              <span class="case-service">{c.service}</span>
            </div>
            <div class="case-body">
              <span class="case-industry">{c.industry}</span>
              <h3>{c.client}</h3>
              <p>{c.challenge}</p>
              <div class="case-metrics-row">
                {Object.entries(c.metrics).map(([key, val]) => (
                  <div class="case-metric-sm">
                    <span class="cm-val">{val}</span>
                    <span class="cm-lbl">{key}</span>
                  </div>
                ))}
              </div>
              <a href={c.slug ? `/casos/${c.slug}/` : "#"} class="case-link">Ver caso completo &rarr;</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Page>

<style>
  .page-hero {
    background: var(--primary);
    color: #fff;
    padding: 10rem 0 5rem;
    text-align: center;
  }

  .page-hero .label {
    display: inline-block;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--accent-3);
    margin-bottom: 1rem;
  }

  .page-hero h1 {
    max-width: 700px;
    margin: 0 auto 1rem;
  }

  .page-hero p {
    max-width: 550px;
    margin: 0 auto;
    color: rgba(255,255,255,0.6);
    font-size: 1.125rem;
  }

  .metrics-bar {
    background: var(--secondary);
    padding: 3rem 0;
  }

  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    text-align: center;
  }

  .metric-val {
    display: block;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 2rem;
    font-weight: 700;
    background: var(--gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .metric-lbl {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.55);
  }

  .filters {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 3rem;
    flex-wrap: wrap;
  }

  .filter-btn {
    padding: 0.5rem 1.25rem;
    border-radius: 50px;
    border: 1px solid var(--border);
    background: transparent;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.3s;
  }

  .filter-btn:hover, .filter-btn.active {
    background: var(--gradient);
    color: #fff;
    border-color: transparent;
  }

  .cases-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .case-card {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: all 0.3s;
  }

  .case-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
  }

  .case-img {
    position: relative;
    height: 220px;
    overflow: hidden;
  }

  .case-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .case-service {
    position: absolute;
    top: 1rem;
    left: 1rem;
    padding: 0.25rem 0.75rem;
    background: var(--gradient);
    border-radius: 50px;
    color: #fff;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .case-body {
    padding: 1.75rem;
  }

  .case-industry {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--accent-1);
  }

  .case-body h3 {
    font-size: 1.25rem;
    margin: 0.375rem 0 0.75rem;
  }

  .case-body p {
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .case-metrics-row {
    display: flex;
    gap: 1.5rem;
    padding: 1rem 0;
    border-top: 1px solid var(--border);
    margin-bottom: 1rem;
  }

  .cm-val {
    display: block;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    background: var(--gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .cm-lbl {
    font-size: 0.7rem;
    color: var(--text-muted);
    text-transform: capitalize;
  }

  .case-link {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--accent-1);
    transition: color 0.3s;
  }

  .case-link:hover {
    color: var(--accent-2);
  }

  @media (max-width: 768px) {
    .cases-grid {
      grid-template-columns: 1fr;
    }
    .metrics-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
